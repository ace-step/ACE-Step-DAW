{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Grep",
      "Glob",
      "Bash(npm test*)",
      "Bash(npm run*)",
      "Bash(npx tsc*)",
      "Bash(npx vitest*)",
      "Bash(npx playwright*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git tag*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(cat*)",
      "Bash(node*)",
      "Bash(npx*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(sudo*)"
    ]
  },
  "hooks": {
    "PreToolCall": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | tail -5; exit $(npx tsc --noEmit 2>&1 | grep -c 'error TS')"
          }
        ]
      }
    ],
    "PostToolCall": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "TSC_ERRORS=$(npx tsc --noEmit --pretty false 2>&1 | grep -c 'error TS' || true); if [ \"$TSC_ERRORS\" -gt 0 ]; then echo \"WARNING: $TSC_ERRORS TypeScript error(s) introduced. Run 'npx tsc --noEmit' to see details.\"; fi"
          }
        ]
      }
    ]
  }
}
